# Force LF for all source files
* text=auto

# Force LF for TypeScript and JavaScript
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf

# Force LF for config files
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.mp4   binary
*.mp3   binary
*.woff  binary
*.woff2 binary
