# ============================================
# OSIRIS-SPECIFIC: LARGE MEDIA & DUPLICATES (R2-ONLY ASSETS)
# ============================================

# ALL media files should be R2-only, not in git
# Video files
generated-assets/video-bg/*.mp4
generated-assets/video-bg/**/*.mp4

# Audio files (both formats)
generated-assets/music-tracks/*.m4a
generated-assets/music-tracks/*.mp3
generated-assets/voices/*.wav
generated-assets/songs+/*.mp3

# Images (keep small ones, exclude large)
generated-assets/images/*.png
generated-assets/images/*.jpg
generated-assets/images/*.jpeg
generated-assets/characters/*.png
generated-assets/characters/*.jpg
generated-assets/characters/*.jpeg

# Temp video clips from video production (~180MB)
generated-assets/master/temp/
generated-assets/master/*.mp4
generated-assets/master/*.json

# Audacity project files (~154MB)
MUSIC-BG/*.aup3

# Duplicate assets in client/public (copied during build)
client/public/generated-assets/

# Video files duplicated in dist (build output)
dist/public/video-bg/
dist/public/generated-assets/

# Duplicate media files - keep dashed names ONLY
# Audio: Keep TRACK-01.m4a, ignore "TRACK 01.m4a" (spaced names)
generated-assets/music-tracks/TRACK *.m4a
generated-assets/music-tracks/TRACK *.mp3

# Voices: Keep VOICE-01.wav, ignore "VOICE 01 — ... .wav"
generated-assets/voices/VOICE *.wav

# Development/Project files (not runtime)
.trae/
.manus-logs/
*.skill
progress-tracker/
audit/

# Documentation (keep minimal)
CINEMATIC_EXPERIENCE_SYSTEM.md
ISSUES_ANALYSIS.md
IMPLEMENTATION_ROADMAP.md
PHASE2_COMPLETION_REPORT.md
PRODUCTION_READINESS_*.md
SYNC_*.md
UX_UI_AUDIT_REPORT.md
REPORT-*.md
todo.md

