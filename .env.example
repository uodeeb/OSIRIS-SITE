# ============================================
# OSIRIS Environment Configuration
# Copy this file to .env.local and fill in your values
# ============================================

# ----------------------------------------
# Frontend Configuration
# ----------------------------------------
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev
VITE_FRONTEND_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ----------------------------------------
# Backend Configuration
# ----------------------------------------
JWT_SECRET=
OAUTH_SERVER_URL=

# Database (PostgreSQL via pg or MySQL via mysql2)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=
PORT=3000

# ----------------------------------------
# Cloudflare R2 Storage Configuration
# ----------------------------------------
# R2 uses S3-compatible API. Get these from your Cloudflare dashboard:
# - Go to R2 > Manage R2 API Tokens
# - Create a token with "Object Read & Write" permission

# Your R2 Access Key ID (from API token)
AWS_ACCESS_KEY_ID=

# Your R2 Secret Access Key (from API token)
AWS_SECRET_ACCESS_KEY=

# Always 'auto' for R2
AWS_REGION=auto

# Your R2 bucket name (e.g., osiris-novel-assets)
S3_BUCKET_NAME=osiris-novel-assets

# Your R2 endpoint URL
# Format: https://{account-id}.r2.cloudflarestorage.com
# Account ID is found in your Cloudflare dashboard right sidebar
S3_ENDPOINT=https://{account-id}.r2.cloudflarestorage.com
